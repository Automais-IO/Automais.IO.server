[Unit]
Description=Automais.io API Service
After=network.target

#   NÃO USAR TYPE NOTIFY!!!!
[Service]
Type=simple
User=root
WorkingDirectory=/root/automais.io/server.io
ExecStart=/usr/bin/dotnet /root/automais.io/server.io/Automais.Api.dll
Restart=always
RestartSec=10
KillSignal=SIGINT
SyslogIdentifier=automais-api

# Timeouts aumentados - a aplicação pode demorar para inicializar (conexão DB, etc)
TimeoutStartSec=300
TimeoutStopSec=60
TimeoutAbortSec=30

# Mesmo arquivo que hosts/remote/routeros/vpnserver/webdevice/manager (AUTOMAIS_*, API_C_SHARP_URL, etc.)
EnvironmentFile=-/root/automais.io/automais.io.env

# Variáveis de ambiente - IMPORTANTE: cada variável em uma linha separada
Environment="ASPNETCORE_ENVIRONMENT=Production"
Environment="ASPNETCORE_URLS=http://0.0.0.0:5000"

# Variáveis de ambiente do banco de dados (substituir ${VAR} no appsettings.json)
